# Sentry — coller ici la DSN du projet Sentry
# Où la trouver : Sentry > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Pour l'upload des source maps (optionnel, améliore le debug)
# Aller sur https://sentry.io/settings/account/api/auth-tokens/ pour créer un token
SENTRY_ORG=
SENTRY_PROJECT=dopatask-os
SENTRY_AUTH_TOKEN=
